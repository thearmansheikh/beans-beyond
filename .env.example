# ─────────────────────────────────────────────────────
# Beans & Beyond — Environment Variables Template
# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# This file IS safe to commit — it contains no secrets.
# ─────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://www.bbcafe.co.uk

# ── Restaurant Info ───────────────────────────────────
NEXT_PUBLIC_RESTAURANT_NAME="Beans & Beyond"
NEXT_PUBLIC_RESTAURANT_PHONE=""
NEXT_PUBLIC_RESTAURANT_EMAIL=""
NEXT_PUBLIC_RESTAURANT_ADDRESS=""

# ── Google Maps ───────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_URL=""
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=""

# ── Social Media ──────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_TIKTOK_URL=""

# ── Delivery Partners ─────────────────────────────────
NEXT_PUBLIC_DELIVEROO_URL=""
NEXT_PUBLIC_UBEREATS_URL=""
NEXT_PUBLIC_JUSTEAT_URL=""

# ── Stripe Payments ───────────────────────────────────
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Newsletter / Mailchimp ────────────────────────────
# https://mailchimp.com/developer/
MAILCHIMP_API_KEY=""
MAILCHIMP_AUDIENCE_ID=""
MAILCHIMP_API_SERVER=""

# ── Database ──────────────────────────────────────────
DATABASE_URL=""

# ── Auth (NextAuth) ───────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Admin ─────────────────────────────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
