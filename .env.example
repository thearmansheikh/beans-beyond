# ─────────────────────────────────────────────────────
# Beans & Beyond — Environment Variables Template
# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# This file IS safe to commit — it contains no secrets.
# ─────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://www.bbcafe.co.uk

# ── Restaurant Info ───────────────────────────────────
NEXT_PUBLIC_RESTAURANT_NAME="Beans & Beyond"
NEXT_PUBLIC_RESTAURANT_PHONE=""
NEXT_PUBLIC_RESTAURANT_EMAIL=""
NEXT_PUBLIC_RESTAURANT_ADDRESS=""

# ── Google Maps ───────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_URL=""
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=""

# ── Social Media ──────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_TIKTOK_URL=""

# ── Delivery Partners ─────────────────────────────────
NEXT_PUBLIC_DELIVEROO_URL=""
NEXT_PUBLIC_UBEREATS_URL=""
NEXT_PUBLIC_JUSTEAT_URL=""

# ── Stripe Payments ───────────────────────────────────
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# From: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Verified sender — must match a domain you've verified in Resend
EMAIL_FROM="Beans & Beyond <noreply@bbcafe.co.uk>"
# Where admin alerts go
ADMIN_EMAIL="admin@bbcafe.co.uk"

# ── Supabase ──────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — NEVER expose to browser. Used in API routes only.
SUPABASE_SERVICE_ROLE_KEY=""

# ── Database ──────────────────────────────────────────
DATABASE_URL=""

# ── Auth (NextAuth) ───────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Admin ─────────────────────────────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
